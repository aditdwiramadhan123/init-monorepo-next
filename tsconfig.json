      "@invitation/hooks": ["packages/hooks/src"],
      "@invitation/hooks/*": ["packages/hooks/src/*"],

      "@invitation/auth": ["packages/auth/src"],
      "@invitation/auth/*": ["packages/auth/src/*"],

      "@invitation/api-client": ["packages/api-client/src"],
      "@invitation/api-client/*": ["packages/api-client/src/*"]
